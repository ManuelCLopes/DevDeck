# Optional: enables GitHub device-flow sign-in in the desktop app.
# Without this, DevDeck still supports pasting a personal access token in Preferences.
DEVDECK_GITHUB_CLIENT_ID=

# Optional: macOS signing identity in base64 `.p12` form for electron-builder.
CSC_LINK=
CSC_KEY_PASSWORD=

# Optional: notarization through an App Store Connect keychain profile.
APPLE_NOTARY_PROFILE=

# Optional: notarization fallback if you are not using a keychain profile.
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=

# Optional: only needed if you want to use the older Drizzle/database tooling.
DATABASE_URL=
