{
  "name": "devdeck",
  "version": "1.0.0",
  "description": "Native macOS workspace dashboard for local repositories and pull request follow-up.",
  "author": "Manuel Lopes",
  "homepage": "https://github.com/ManuelCLopes/DevDeck",
  "bugs": {
    "url": "https://github.com/ManuelCLopes/DevDeck/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ManuelCLopes/DevDeck.git"
  },
  "keywords": [
    "electron",
    "github",
    "git",
    "macos",
    "pull-requests",
    "repositories",
    "review",
    "workspace"
  ],
  "type": "module",
  "main": "dist-electron/main.cjs",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron:watch\" \"npm:dev:electron\"",
    "dev:client": "vite dev --host 127.0.0.1 --port 5000",
    "dev:electron": "wait-on tcp:127.0.0.1:5000 file:dist-electron/main.cjs file:dist-electron/preload.cjs && DEVDECK_RENDERER_URL=http://127.0.0.1:5000 electron dist-electron/main.cjs",
    "dev:electron:watch": "tsx script/build-electron.ts --watch",
    "dev:renderer": "npm run dev:client",
    "dev:web": "NODE_ENV=development tsx server/index.ts",
    "build": "npm run build:web && npm run build:electron",
    "build:electron": "tsx script/build-electron.ts",
    "build:web": "tsx script/build.ts",
    "dist:mac": "node script/generate-icon.cjs && npm run build && electron-builder --mac",
    "pack:mac": "node script/generate-icon.cjs && npm run build && electron-builder --mac dir",
    "release:check": "node script/release-preflight.cjs",
    "release:check:artifacts": "node script/release-preflight.cjs --require-artifacts",
    "release:check:final": "node script/release-preflight.cjs --require-artifacts --require-signing --require-notarization --require-github-auth --verify-codesign --verify-notarization",
    "release:check:prod": "node script/release-preflight.cjs --require-signing --require-notarization --require-github-auth",
    "rc:check": "npm run check && npm test && npm run test:e2e && npm run pack:mac && npm run release:check:artifacts",
    "start": "NODE_ENV=production node dist/index.cjs",
    "electron:rebuild": "electron-rebuild -f -w node-pty",
    "check": "tsc",
    "test": "tsx --test client/src/lib/*.test.ts shared/*.test.ts electron/*.test.ts",
    "test:e2e": "playwright test",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.10.0",
    "@jridgewell/trace-mapping": "^0.3.25",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.7",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.60.5",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "connect-pg-simple": "^10.0.0",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "embla-carousel-react": "^8.6.0",
    "express": "^5.0.1",
    "express-session": "^1.18.1",
    "framer-motion": "^12.23.24",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.545.0",
    "memorystore": "^1.6.7",
    "next-themes": "^0.4.6",
    "node-pty": "^1.0.0",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "pg": "^8.16.3",
    "react": "^19.2.0",
    "react-day-picker": "^9.11.1",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.66.0",
    "react-resizable-panels": "^2.1.9",
    "recharts": "^2.15.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "wouter": "^3.3.5",
    "ws": "^8.18.0",
    "zod": "^3.25.76",
    "zod-validation-error": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.14",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.0",
    "@types/express-session": "^1.18.0",
    "@types/node": "^20.19.0",
    "@types/passport": "^1.0.16",
    "@types/passport-local": "^1.0.38",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@types/ws": "^8.5.13",
    "@electron/rebuild": "^4.0.1",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.4",
    "electron": "^37.3.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.25.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.20.5",
    "typescript": "5.6.3",
    "vite": "^7.1.9",
    "wait-on": "^8.0.5"
  },
  "optionalDependencies": {
    "bufferutil": "^4.0.8"
  },
  "build": {
    "appId": "com.manuelclopes.devdeck",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "afterSign": "script/notarize.cjs",
    "productName": "DevDeck",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/public/**/*",
      "package.json"
    ],
    "extraResources": [
      "build/icon.png"
    ],
    "dmg": {
      "backgroundColor": "#eff4fb",
      "contents": [
        {
          "type": "file",
          "x": 150,
          "y": 185
        },
        {
          "path": "/Applications",
          "type": "link",
          "x": 390,
          "y": 185
        }
      ],
      "iconSize": 140,
      "window": {
        "width": 560,
        "height": 400
      }
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "gatekeeperAssess": false,
      "hardenedRuntime": true,
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
